# ============================================================
# EBI Telegram Bots – Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── TELEGRAM ─────────────────────────────────────────────────
# Get from @BotFather on Telegram
MARKET_BOT_TOKEN=your_market_bot_token_here
COMMUNITY_BOT_TOKEN=your_community_bot_token_here

# Telegram group/channel IDs (negative numbers for groups, e.g. -1001234567890)
MARKET_GROUP_ID=-1001234567890
COMMUNITY_GROUP_ID=-1001234567890

# Comma-separated Telegram user IDs for admins (e.g. 123456789,987654321)
ADMIN_IDS=123456789

# ── AI ────────────────────────────────────────────────────────
# Google Gemini – FREE tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── DATABASE ──────────────────────────────────────────────────
# Supabase – FREE tier: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── NEWS (optional, improves quality) ────────────────────────
# NewsAPI – FREE 100 req/day: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# CryptoPanic – FREE: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here

# ── SETTINGS ─────────────────────────────────────────────────
TIMEZONE=Asia/Singapore

# Community name used in welcome messages
COMMUNITY_NAME=Elite by Infinity

# How often to check for breaking news (minutes)
NEWS_CHECK_INTERVAL=15

# How many hours back to look for breaking news
NEWS_LOOKBACK_HOURS=2
